<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Our Team | Forge Partners, Inc.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --navy-deep: #0F1628;
    --navy-mid: #1A1A2E;
    --navy-light: #1A3A6A;
    --gold: #C9A84C;
    --gold-light: #E8C97A;
    --cream: #F5F0E8;
    --white: #FFFFFF;
    --text-muted: #8A9BB0;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--navy-deep);
    color: var(--cream);
    overflow-x: hidden;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.2rem 5%;
    background: rgba(15,22,40,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(201,168,76,0.15);
  }
  .nav-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--white);
    text-decoration: none;
  }
  .nav-logo span { color: var(--gold); }
  .nav-links {
    display: flex; align-items: center; gap: 2.5rem;
    list-style: none;
  }
  .nav-links a {
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cream);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s, color 0.2s;
  }
  .nav-links a:hover, .nav-links a.active { opacity: 1; color: var(--gold-light); }
  .nav-cta {
    font-size: 0.78rem !important;
    letter-spacing: 0.12em !important;
    color: var(--navy-deep) !important;
    background: var(--gold);
    padding: 0.6rem 1.4rem;
    opacity: 1 !important;
  }
  .nav-cta:hover { background: var(--gold-light) !important; }

  /* ─── PAGE HERO ─── */
  .page-hero {
    padding: 10rem 5% 5rem;
    position: relative;
    overflow: hidden;
  }
  .page-hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 60% 60% at 80% 40%, rgba(26,58,106,0.3) 0%, transparent 70%),
      linear-gradient(160deg, #0F1628 0%, #0d1220 100%);
  }
  .page-hero-grid {
    position: absolute; inset: 0; opacity: 0.03;
    background-image:
      linear-gradient(rgba(201,168,76,0.5) 1px, transparent 1px),
      linear-gradient(90deg, rgba(201,168,76,0.5) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .page-hero-content {
    position: relative; z-index: 2;
    max-width: 680px;
  }
  .page-eyebrow {
    display: inline-flex; align-items: center; gap: 0.75rem;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }
  .page-eyebrow::before {
    content: '';
    display: block; width: 2rem; height: 1px;
    background: var(--gold);
  }
  .page-hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    font-weight: 300;
    line-height: 1.15;
    color: var(--white);
    margin-bottom: 1.2rem;
  }
  .page-hero h1 em { font-style: italic; color: var(--gold-light); }
  .page-hero-sub {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--text-muted);
    max-width: 560px;
  }

  /* ─── FOUNDER SECTION ─── */
  .founder-section {
    padding: 6rem 5%;
    background: var(--navy-mid);
  }

  .founder-grid {
    display: grid;
    grid-template-columns: 340px 1fr;
    gap: 5rem;
    align-items: start;
    max-width: 1100px;
  }

  .founder-portrait {
    position: sticky;
    top: 7rem;
  }

  .portrait-frame {
    width: 100%;
    aspect-ratio: 3/4;
    background: rgba(26,58,106,0.25);
    border: 1px solid rgba(201,168,76,0.2);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .portrait-frame::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, var(--gold), transparent);
  }
  .portrait-placeholder {
    font-family: 'Cormorant Garamond', serif;
    font-size: 5rem;
    font-weight: 300;
    color: var(--gold);
    opacity: 0.3;
    line-height: 1;
  }
  .portrait-initials {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    letter-spacing: 0.3em;
    color: var(--text-muted);
    margin-top: 0.5rem;
    text-transform: uppercase;
  }

  .founder-meta {
    margin-top: 1.5rem;
  }
  .founder-name-block h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--white);
    line-height: 1.2;
    margin-bottom: 0.3rem;
  }
  .founder-title {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.2rem;
  }
  .founder-badges {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
    margin-top: 1rem;
  }
  .f-badge {
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(201,168,76,0.3);
    padding: 0.3rem 0.7rem;
    opacity: 0.85;
  }

  .founder-bio {}
  .bio-section {
    margin-bottom: 2.8rem;
    padding-bottom: 2.8rem;
    border-bottom: 1px solid rgba(201,168,76,0.1);
  }
  .bio-section:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

  .bio-label {
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
    display: flex; align-items: center; gap: 0.75rem;
  }
  .bio-label::after {
    content: '';
    flex: 1; height: 1px;
    background: rgba(201,168,76,0.15);
    max-width: 60px;
  }

  .bio-section p {
    font-size: 0.95rem;
    line-height: 1.85;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .bio-section p:last-child { margin-bottom: 0; }

  .credential-stack {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .credential-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.2rem;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(201,168,76,0.1);
    transition: border-color 0.25s;
  }
  .credential-item:hover { border-color: rgba(201,168,76,0.3); }
  .cred-icon {
    color: var(--gold);
    font-size: 0.9rem;
    margin-top: 0.1rem;
    flex-shrink: 0;
  }
  .cred-text {}
  .cred-label {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 0.2rem;
  }
  .cred-sub {
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  /* ─── DISCIPLINE VISUAL ─── */
  .discipline-wheel {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: rgba(201,168,76,0.12);
    border: 1px solid rgba(201,168,76,0.12);
    margin-top: 0.5rem;
    overflow: hidden;
  }
  .discipline-cell {
    background: var(--navy-mid);
    padding: 1.8rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.6rem;
    transition: background 0.25s;
  }
  .discipline-cell:hover { background: rgba(26,58,106,0.5); }
  .discipline-cell.center-cell {
    background: rgba(201,168,76,0.07);
    align-items: center;
    text-align: center;
    justify-content: center;
    border-left: 1px solid rgba(201,168,76,0.2);
    border-right: 1px solid rgba(201,168,76,0.2);
  }
  .disc-glyph {
    font-size: 1.6rem;
    line-height: 1;
    color: var(--gold);
    opacity: 0.7;
  }
  .disc-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--white);
    line-height: 1.2;
  }
  .disc-desc {
    font-size: 0.75rem;
    color: var(--text-muted);
    line-height: 1.5;
  }
  .disc-center-label {
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.4rem;
  }
  .disc-center-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--white);
    line-height: 1.4;
    text-align: center;
  }

  /* ─── METHODOLOGY GUARANTEE ─── */
  .method-guarantee {
    margin-top: 2.5rem;
    border: 1px solid rgba(201,168,76,0.2);
    background: rgba(201,168,76,0.04);
    padding: 2rem 2.2rem;
  }
  .method-guarantee-label {
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.75rem;
  }
  .method-guarantee-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--white);
    margin-bottom: 1rem;
    line-height: 1.4;
  }
  .method-guarantee-items {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .method-guarantee-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.55;
  }
  .method-guarantee-item::before {
    content: '◆';
    color: var(--gold);
    font-size: 0.5rem;
    margin-top: 0.35rem;
    flex-shrink: 0;
  }

  .edu-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
    margin-top: 0.5rem;
  }
  .edu-item {
    padding: 1rem 1.2rem;
    background: rgba(255,255,255,0.02);
    border-left: 2px solid rgba(201,168,76,0.3);
  }
  .edu-school {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 0.2rem;
  }
  .edu-field {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  /* ─── CONSULTANT SECTION ─── */
  .consultant-section {
    padding: 6rem 5%;
    background: var(--navy-deep);
  }

  .section-eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1rem;
  }
  h2.section-h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 300;
    line-height: 1.2;
    color: var(--white);
    margin-bottom: 3rem;
  }
  h2.section-h2 em { font-style: italic; color: var(--gold-light); }

  .consultant-card {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 4rem;
    align-items: start;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(201,168,76,0.12);
    padding: 3rem;
    max-width: 900px;
  }

  .consultant-portrait {
    width: 100%;
    aspect-ratio: 1/1;
    background: rgba(26,58,106,0.25);
    border: 1px solid rgba(201,168,76,0.2);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  .consultant-portrait::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 3px;
    background: linear-gradient(90deg, var(--gold), transparent);
  }

  .consultant-info {}
  .consultant-info h3 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.7rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 0.3rem;
  }
  .consultant-title-tag {
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }
  .consultant-info p {
    font-size: 0.92rem;
    line-height: 1.85;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }
  .consultant-info p:last-of-type { margin-bottom: 1.5rem; }

  .consultant-tags {
    display: flex; flex-wrap: wrap; gap: 0.5rem;
  }
  .c-tag {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(201,168,76,0.25);
    padding: 0.3rem 0.7rem;
    opacity: 0.8;
  }

  /* ─── JOIN CTA ─── */
  .join-section {
    padding: 5rem 5%;
    background: var(--navy-mid);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .join-section h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    font-weight: 300;
    color: var(--white);
    margin-bottom: 1rem;
    max-width: 560px;
    line-height: 1.3;
  }
  .join-section h2 em { font-style: italic; color: var(--gold-light); }
  .join-section p {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--text-muted);
    max-width: 500px;
    margin-bottom: 2rem;
  }
  .btn-primary {
    display: inline-block;
    padding: 0.9rem 2rem;
    background: var(--gold);
    color: var(--navy-deep);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: var(--gold-light); }

  /* ─── FOOTER ─── */
  footer {
    background: #080d18;
    padding: 3rem 5%;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 1.5rem;
    border-top: 1px solid rgba(201,168,76,0.1);
  }
  .footer-logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--white);
  }
  .footer-logo span { color: var(--gold); }
  .footer-copy {
    font-size: 0.75rem;
    color: var(--text-muted);
    opacity: 0.5;
    text-align: center;
  }
  .footer-badges { display: flex; gap: 1rem; }
  .badge {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(201,168,76,0.3);
    padding: 0.3rem 0.7rem;
    opacity: 0.7;
  }

  /* ─── ANIMATIONS ─── */
  .fade-up {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .fade-up.visible { opacity: 1; transform: translateY(0); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 900px) {
    .founder-grid { grid-template-columns: 1fr; gap: 3rem; }
    .founder-portrait { position: static; }
    .portrait-frame { aspect-ratio: 1/1; max-width: 240px; }
    .consultant-card { grid-template-columns: 1fr; gap: 2rem; }
    .consultant-portrait { max-width: 200px; aspect-ratio: 1/1; }
    .nav-links { display: none; }
    .credential-stack, .edu-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .timeline-item { grid-template-columns: 1fr; gap: 0.3rem; }
  }
</style>
</head>
