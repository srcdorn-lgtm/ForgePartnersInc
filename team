<!-- PAGE HERO -->
<div class="page-hero">
  <div class="page-hero-bg"></div>
  <div class="page-hero-grid"></div>
  <div class="page-hero-content fade-up">
    <div class="page-eyebrow">The People Behind the Methodology</div>
    <h1>Built by <em>practitioners.</em><br>Delivered by practitioners.</h1>
